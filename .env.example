NEXT_PUBLIC_WS_SHIPS_URL="ws://localhost:3003"
NEXT_PUBLIC_WS_MEMORY_URL="ws://localhost:3004"
NEXT_PUBLIC_WS_2048_URL="ws://localhost:3005"

# WebSocket servers — produção Railway (servidor unificado ws-unified.js)
